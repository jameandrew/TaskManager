<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TaskManager.ViewModels"
             x:Class="TaskManager.Views.AddTaskPage"
             x:DataType="viewmodels:AddTaskViewModel"
             Title="Add Task"
             BackgroundColor="#1C1C1E"
             Shell.NavBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Header -->
            <Label Text="Add New Task" 
                   FontSize="32"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"/>

            <!-- Category Selection -->
            <VerticalStackLayout Spacing="15">
                <Label Text="SELECT CATEGORY"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#8E8E93"/>

                <Border Stroke="#8E8E93" 
                        StrokeThickness="1"
                        Padding="15"
                        BackgroundColor="#2C2C2E">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Category" 
                               FontSize="14"
                               TextColor="#8E8E93"/>

                        <Picker x:Name="CategoryPicker"
                                Title="Choose a category"
                                ItemsSource="{Binding AvailableCategories}"
                                SelectedItem="{Binding SelectedCategory}"
                                TextColor="White"
                                TitleColor="#8E8E93"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Custom Category Input -->
                <Border Stroke="#8E8E93" 
                        StrokeThickness="1"
                        Padding="15"
                        IsVisible="{Binding IsCustomCategoryVisible}"
                        BackgroundColor="#2C2C2E">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="15">
                        <Label Text="CREATE CUSTOM CATEGORY"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"/>

                        <Label Text="Category Name" 
                               FontSize="14"
                               TextColor="#8E8E93"/>
                        <Entry Placeholder="e.g., Gaming, Music, etc."
                               Text="{Binding CustomCategoryName}"
                               PlaceholderColor="#8E8E93"
                               TextColor="White"
                               BackgroundColor="#1C1C1E"/>

                        <Button Text="Add Category"
                                Command="{Binding AddCustomCategoryCommand}"
                                BackgroundColor="#28A745"
                                TextColor="White"
                                FontSize="16"
                                FontAttributes="Bold"
                                Padding="15"
                                CornerRadius="10"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Task Details Section -->
            <VerticalStackLayout Spacing="15" IsVisible="{Binding IsAddTaskVisible}">
                <Label Text="TASK DETAILS"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#8E8E93"/>

                <Border Stroke="#8E8E93" 
                        StrokeThickness="1"
                        Padding="15"
                        BackgroundColor="#2C2C2E">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Task Name" 
                               FontSize="14"
                               TextColor="#8E8E93"/>
                        <Entry Placeholder="Enter task name"
                               Text="{Binding TaskName}"
                               PlaceholderColor="#8E8E93"
                               TextColor="White"
                               BackgroundColor="#1C1C1E"/>

                        <Label Text="Description (Optional)" 
                               FontSize="14"
                               TextColor="#8E8E93"
                               Margin="0,10,0,0"/>
                        <Entry Placeholder="Enter task description"
                               Text="{Binding TaskDescription}"
                               PlaceholderColor="#8E8E93"
                               TextColor="White"
                               BackgroundColor="#1C1C1E"/>

                        <Label Text="Due Date" 
                               FontSize="14"
                               TextColor="#8E8E93"
                               Margin="0,10,0,0"/>
                        <DatePicker Date="{Binding DueDate}"
                                    Format="D"
                                    TextColor="White"
                                    BackgroundColor="#1C1C1E"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Add Task Button -->
                <Button Text="+ Add Task"
                        Command="{Binding AddTaskCommand}"
                        BackgroundColor="#007AFF"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        Padding="20"
                        CornerRadius="15"
                        Margin="0,20,0,0"/>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>