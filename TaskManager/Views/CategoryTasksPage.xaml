<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:TaskManager.ViewModels"
             xmlns:models="clr-namespace:TaskManager.Models"
             x:Class="TaskManager.Views.CategoryTasksPage"
             x:DataType="viewmodels:CategoryTasksViewModel"
             BackgroundColor="#1C1C1E">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Category Header -->
            <Grid ColumnDefinitions="50,*" ColumnSpacing="15">
                <!-- Icon -->
                <Border Grid.Column="0"
                        BackgroundColor="{Binding CategoryIconBackgroundColor}"
                        WidthRequest="50"
                        HeightRequest="50"
                        StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12"/>
                    </Border.StrokeShape>
                    <Label Text="{Binding CategoryIcon}"
                           FontSize="24"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Category Info -->
                <VerticalStackLayout Grid.Column="1" 
                                     Spacing="5"
                                     VerticalOptions="Center">
                    <Label Text="{Binding CategoryName}"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="{Binding CategoryTaskCount}"
                           FontSize="14"
                           TextColor="#8E8E93"/>
                </VerticalStackLayout>
            </Grid>

            <!-- Tasks List -->
            <Label Text="TASKS"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="#8E8E93"
                   Margin="0,10,0,0"/>

            <CollectionView ItemsSource="{Binding CategoryTasks}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TaskItem">
                        <Border Margin="0,5"
                                BackgroundColor="#2C2C2E"
                                Padding="15"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:CategoryTasksViewModel}}, Path=TaskSelectedCommand}"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10">
                                <!-- Task Name -->
                                <Label Grid.Row="0"
                                       Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="White"/>

                                <!-- Description -->
                                <Label Grid.Row="1"
                                       Text="{Binding Description}"
                                       FontSize="14"
                                       TextColor="#8E8E93"
                                       Margin="0,5,0,0"
                                       IsVisible="{Binding HasDescription}"/>

                                <!-- Due Date Badge -->
                                <HorizontalStackLayout Grid.Row="2" 
                                                       Margin="0,10,0,0"
                                                       Spacing="10">
                                    <Border BackgroundColor="{Binding DueDateBadgeColor}"
                                            Padding="8,4"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="4"/>
                                        </Border.StrokeShape>
                                        <Label Text="{Binding DueDateFormatted}"
                                               FontSize="12"
                                               TextColor="White"/>
                                    </Border>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="40" Spacing="10">
                        <Label Text="No tasks in this category"
                               FontSize="16"
                               TextColor="#8E8E93"
                               HorizontalOptions="Center"/>
                        <Label Text="Tap 'Add Task' to create one"
                               FontSize="14"
                               TextColor="#8E8E93"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

            <!-- Add Task Button -->
            <Button Text="+ Add Task to This Category"
                    Command="{Binding AddTaskCommand}"
                    BackgroundColor="#007AFF"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    Padding="20"
                    CornerRadius="15"
                    Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>